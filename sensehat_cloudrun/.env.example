# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copia este fichero a ".env" para desarrollo local
# NUNCA subas el fichero ".env" real a Git (está en .gitignore)
#
# CREDENCIALES: no se configuran aquí.
# En local se usan las ADC de tu máquina (ver instrucciones).
# En Cloud Run las gestiona automáticamente la cuenta de servicio del servicio.
# ─────────────────────────────────────────────────────────────────────────────

# ID del proyecto GCP (en Cloud Run se detecta automáticamente)
GOOGLE_CLOUD_PROJECT=tu-proyecto-gcp

# Nombre del dataset de BigQuery (por defecto: midataset)
BQ_DATASET=midataset

# Nombre de la tabla (por defecto: mitabla)
BQ_TABLE=mitabla

# Localización del dataset (EU o US)
BQ_LOCATION=EU
