# ─────────────────────────────────────────────────────────────────────────────
# .env.example — copia este fichero a ".env" para desarrollo local
# NUNCA subas el fichero ".env" real a Git (está en .gitignore)
# ─────────────────────────────────────────────────────────────────────────────

# Cadena de conexión de Cosmos DB (se obtiene en Azure Portal > Cosmos DB > Keys)
COSMOS_CONNECTION_STRING=AccountEndpoint=https://<tu-cuenta>.documents.azure.com:443/;AccountKey=<tu-clave>;

# Nombre de la base de datos (por defecto: mibd)
COSMOS_DATABASE=mibd

# Nombre del contenedor (por defecto: micontenedor)
COSMOS_CONTAINER=micontenedor
